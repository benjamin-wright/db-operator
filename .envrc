# direnv — automatically scopes KUBECONFIG to the local db-operator cluster.
# This prevents kubectl / helm / tilt from accidentally targeting a remote cluster.
#
# The kubeconfig file is written by `make cluster-up`.
# Override CLUSTER_NAME if you used a non-default name:
#   CLUSTER_NAME=my-cluster direnv allow

export KUBECONFIG="${HOME}/.scratch/db-operator.yaml"
